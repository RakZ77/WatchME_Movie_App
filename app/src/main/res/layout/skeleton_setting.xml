<!-- res/layout/skeleton_setting.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:background="@drawable/bg_setting_card_better"
    android:orientation="vertical">

    <!-- Contact info skeleton -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <View android:layout_width="80dp" android:layout_height="16dp"
            android:background="@color/skeleton_color" android:layout_marginBottom="6dp"/>

        <View
            android:layout_width="160dp"
            android:layout_height="16dp"
            android:background="@color/skeleton_color" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#787878"/>

    <!-- Birthday skeleton -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <View android:layout_width="60dp" android:layout_height="16dp"
            android:background="@color/skeleton_color" android:layout_marginBottom="6dp"/>
        <View android:layout_width="120dp" android:layout_height="16dp"
            android:background="@color/skeleton_color"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#787878"/>

    <!-- Profile Name skeleton -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <View android:layout_width="90dp" android:layout_height="16dp"
            android:background="@color/skeleton_color" android:layout_marginBottom="6dp"/>
        <View android:layout_width="140dp" android:layout_height="16dp"
            android:background="@color/skeleton_color"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#787878"/>

    <!-- Gender skeleton -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <View android:layout_width="55dp" android:layout_height="16dp"
            android:background="@color/skeleton_color" android:layout_marginBottom="6dp"/>
        <View android:layout_width="80dp" android:layout_height="16dp"
            android:background="@color/skeleton_color"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#787878"/>

    <!-- Location skeleton -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <View android:layout_width="65dp" android:layout_height="16dp"
            android:background="@color/skeleton_color" android:layout_marginBottom="6dp"/>
        <View android:layout_width="110dp" android:layout_height="16dp"
            android:background="@color/skeleton_color"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#787878" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Change Profile"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_arrow_right"
            app:tint="#FFFFFF" />
    </LinearLayout>

</LinearLayout>